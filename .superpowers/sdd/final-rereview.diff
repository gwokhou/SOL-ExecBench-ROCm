+        lambda: probe,
+    )
+
+    artifact = run_calibration(
+        CalibrationRequest(environment=GpuEnvironment(device=0, architecture="gfx942"))
+    )
+
+    assert all(candidate.state == "measured" for candidate in artifact.candidates)
+
+
