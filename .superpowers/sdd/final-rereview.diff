+    class Runtime:
+        def architecture_for(self, device: int) -> str:
+            assert device == 2
+            return "GFX950"
+
+    environment = discover_gpu(2, Runtime())
+
+    assert environment.device == 2
+    assert environment.architecture == "gfx950"
