+        for candidate in candidates
+    )
+    assert {
+        (candidate.kind, candidate.operation, candidate.path)
+        for candidate in candidates
+    } >= {
+        ("compute", "vector", "portable"),
+        ("memory", "stream_copy", "portable"),
+    }
+
+
