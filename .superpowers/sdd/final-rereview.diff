+    assert artifact.metadata["clock_lock_reason"] == "clock_lock_adapter_unavailable"
+
+
+def test_request_without_injected_probe_uses_default_backend(monkeypatch) -> None:
+    probe = _probe()
+    monkeypatch.setattr(
