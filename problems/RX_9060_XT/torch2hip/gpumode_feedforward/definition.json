  "outputs": {
    "output": {
      "shape": [
        "OB",
        "1"
      ],
      "dtype": "float32",
      "description": "sigmoid(linear2(relu(linear1(vstack(x,y)))))."
    }
  },
  "reference": "import torch\nimport torch.nn.functional as F\n\ndef run(x, y, fc1_weight, fc1_bias, fc2_weight, fc2_bias):\n    inp = torch.vstack([x, y])\n    hidden = F.linear(inp, fc1_weight, fc1_bias)\n    relu = F.relu(hidden)\n    output = F.linear(relu, fc2_weight, fc2_bias)\n    return torch.sigmoid(output)\n"
