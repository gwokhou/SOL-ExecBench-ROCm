{
  "name": "gpumode_feedforward",
  "op_type": "matmul",
  "description": "Fused two-input feedforward: vstack(x,y) -> linear -> ReLU -> linear -> sigmoid. Derived from AKA torch2hip/gpumode/10024_Feedforward module_fn.",
  "axes": {
