        "C"
      ],
      "dtype": "float32",
      "description": "Second input (B, C)."
    },
    "fc1_weight": {
      "shape": [
        "H",
        "C"
      ],
      "dtype": "float32",
      "description": "First linear weight (H, C)."
    },
    "fc1_bias": {
      "shape": [
        "H"
      ],
      "dtype": "float32",
      "description": "First linear bias (H,)."
    },
    "fc2_weight": {
      "shape": [
        "1",
        "H"
      ],
      "dtype": "float32",
      "description": "Second linear weight (1, H)."
